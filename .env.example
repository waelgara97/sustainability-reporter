# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Brave Search API (required) ───────────────────────────────────────────────
#
# The app uses the official Brave Search API to find sustainability report URLs.
#
# Step 1 — Sign up and get a free API key:
#   https://api-dashboard.search.brave.com/
#   → Create an account → API Keys → Generate key
#
# Free tier: ~1,000 queries/month ($5 credit at $5 per 1,000 queries).
# The app hard-stops at 950 queries/month to keep a safety buffer.
# Each crawler run uses 1 query per company (e.g. 50 companies = 50 queries).

BRAVE_API_KEY=your_brave_api_key_here
