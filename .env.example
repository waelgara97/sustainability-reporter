# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Google Custom Search API (required) ───────────────────────────────────────
#
# The app uses the official Google Custom Search JSON API to find sustainability
# report URLs.  Scraping google.com directly is unreliable and violates Google's
# Terms of Service.
#
# Step 1 — Get an API key (free):
#   https://console.cloud.google.com/
#   → APIs & Services → Credentials → Create Credentials → API key
#   → Enable "Custom Search API" for that key
#
# Step 2 — Create a Custom Search Engine:
#   https://programmablesearchengine.google.com/
#   → New search engine → Search the entire web → Copy the "Search engine ID"
#
# Free quota: 100 queries per day.
# Each crawler run uses 1 query per company (e.g. 20 companies = 20 queries).

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here
